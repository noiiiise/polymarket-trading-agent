# Polymarket Trading Agent — Credentials
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# Polymarket CLOB API key
POLYMARKET_API_KEY=

# Private key for signing on-chain transactions (hex, no 0x prefix)
POLYMARKET_PRIVATE_KEY=

# Your Polygon wallet address (0x...)
POLYMARKET_WALLET_ADDRESS=

# GitHub personal access token (for STRATEGY_DOC.md commits)
GITHUB_TOKEN=

# GitHub repo owner (your username or org)
GITHUB_OWNER=

# GitHub repo name (default: polymarket-trading-agent)
GITHUB_REPO=polymarket-trading-agent

# GitHub branch to commit to
GITHUB_BRANCH=main

# Polygon RPC endpoint (default: public RPC)
POLYGON_RPC_URL=https://polygon-rpc.com

# SQLite database path
SQLITE_DB_PATH=data/agent.db

# Set to "true" to run in simulation mode (no real trades)
PAPER_TRADING=true

# Paper trading initial simulated balance
# PAPER_TRADING_INITIAL_BALANCE=10000
